---
import "../styles/global.css";
import Button from "../components/Button.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { RubiksCube } from "../lib/motion-core";
---

<BaseLayout title="Rino Godson">
  <main
    class="min-h-dvh w-svw bg-[#111214] text-white flex flex-col px-6 py-12 md:px-12 lg:px-24 font-[Rubik] overflow-hidden"
  >
    <div class="grid grid-cols-1 lg:grid-cols-2 w-full flex-1 gap-8 lg:gap-12">
      <div
        class="order-last lg:order-first flex flex-col justify-end h-full pb-8 lg:pb-12 z-10"
      >
        <div class="space-y-6 lg:space-y-8">
          <div>
            <h1 class="text-5xl md:text-6xl font-bold tracking-tight">
              Rino Godson
            </h1>
            <p class="text-gray-500 font-medium text-lg md:text-xl mt-2">
              he/him • <span class="text-gray-400">Programmer</span>
            </p>
          </div>

          <p
            class="text-gray-400 max-w-md leading-relaxed text-base md:text-lg"
          >
            i'm hands-off with docs. i learn by building - sometimes small,
            sometimes wild. i like turning ideas into real, working stuff. even
            if it's half-broken at first, it works... eventually.
          </p>

          <div
            class="flex flex-col sm:flex-row gap-4 pt-2 w-full button-container"
          >
            <Button text="Socials" icon="mdi:heart" href="#" />
            <Button text="Projects" icon="lucide:origami" href="#" />
            <Button text="Resume" icon="lucide:file-text" href="#" />
          </div>
        </div>
      </div>

      <div
        class="order-first lg:order-last w-full h-full flex justify-center items-center saturate-0 mt-8 lg:mt-0"
      >
        <div
          class="w-full sm:max-w-sm lg:max-w-none lg:w-full lg:h-full aspect-square flex items-center justify-center"
        >
          <RubiksCube client:load class="h-full w-full" />
        </div>
      </div>
    </div>

    <div
      class="fixed bottom-6 right-6 lg:bottom-auto lg:top-24 lg:left-24 md:bottom-10 md:right-10 scale-[0.65] md:scale-100 origin-bottom-right lg:origin-top-left z-50 pointer-events-none"
    >
      <div
        class="relative w-32 h-32 flex items-center justify-center pointer-events-auto"
      >
        <div class="absolute inset-0 animate-spin-slow">
          <svg viewBox="0 0 100 100" class="w-full h-full">
            <path
              id="circlePath"
              d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0"
              fill="none"></path>
            <text font-size="11" fill="white" font-weight="bold">
              <textPath href="#circlePath" letter-spacing="1">
                GO TO MY CHANNEL • GO TO MY CHANNEL •
              </textPath>
            </text>
          </svg>
        </div>
        <div class="bg-white rounded-full p-4 text-black shadow-xl">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M7 17l10-10M7 7h10v10"></path></svg
          >
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .animate-spin-slow {
    animation: spin 10s linear infinite;
  }
  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 640px) {
    a {
      width: 100% !important;
      justify-content: center !important;
    }
    .button-container :global(button),
    .button-container :global(a) {
      width: 100% !important;
      justify-content: center !important;
    }
  }
</style>
