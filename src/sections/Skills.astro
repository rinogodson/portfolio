---
import { getCollection } from "astro:content";

const allStackItems = await getCollection("stack");
const sortedStack = allStackItems.sort((a, b) => a.data.order - b.data.order);
---

<section class="text-white py-16 px-8 md:px-20 h-fit font-sans">
  <div>
    <h2 class="text-4xl font-bold mb-16 tracking-tight">Technical Stack:</h2>

    <div class="grid grid-cols-2 lg:grid-cols-4 w-full gap-x-8 gap-y-12">
      {
        sortedStack.map((category) => (
          <div class="flex flex-col">
            <h3 class="text-[10px] uppercase tracking-[0.2em] text-zinc-500 font-bold mb-3">
              {category.data.title}
            </h3>
            <div class="h-px w-full bg-zinc-800 mb-6" />

            <ul class="flex flex-col gap-y-3">
              {category.data.items.map((item) => (
                <li class="text-zinc-300 text-lg font-medium hover:text-white transition-colors cursor-default">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
