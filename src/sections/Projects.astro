---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import story from "../assets/story.webp";
import ProjectsStack from "../components/ProjectsStack.tsx";
import { getCollection } from "astro:content";
const projectEntries = await getCollection("projects");
const projectsList = projectEntries[0]?.data.projects ?? [];
const sortedProjects = projectsList.sort((a, b) => a.id - b.id);
---

<section
  id="projects"
  class="flex flex-col mt-10 w-full md:flex-row font-[Rubik]"
>
  <div
    class="w-full md:w-[50%] py-12 md:py-0 px-6 md:px-12 lg:px-24 bg-[#111214] text-white font-[Rubik] flex flex-col justify-center items-start relative overflow-hidden"
  >
    <div class="w-full flex justify-center items-center mb-10">
      <Image src={story} alt="Story Image" class={"w-[70%] opacity-30"} />
    </div>
    <h2 class="text-4xl font-medium mb-10 tracking-tight">My Story</h2>
    <p class="text-lg leading-relaxed mb-8">
      i'm hands-off with docs. i learn by building - sometimes small, sometimes
      wild. i like turning ideas into real, working stuff. even if it's
      half-broken at first, it works... eventually. here are my socials:i'm
      hands-off with docs. i learn by building - sometimes small, sometimes
      wild. i like turning ideas into real, working stuff. even if it's
      half-broken at first, it works... eventually. here are my socials:
    </p>
  </div>
  <div
    class="w-full md:w-[50%] py-6 md:py-0 md:pb-10 px-6 md:px-12 lg:px-24 bg-[#111214] text-white font-[Rubik] relative overflow-clip"
  >
    <h2
      class="md:text-3xl text-2xl w-full md:text-start flex text-center font-medium mb-10 tracking-tight"
    >
      My Projects:
      <span
        class="text-sm md:text-base ml-4 flex items-center gap-1 opacity-70 bg-neutral-800 px-3 rounded-full"
      >
        <Icon name="material-symbols:swipe-rounded" class="w-5 h-5" />
        Swipe to view
      </span>
    </h2>

    <ProjectsStack pro={sortedProjects} client:load />
  </div>
</section>
