---
const { title = "Rino Godson | Portfolio" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/webp" href="/fav.webp" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-[#111214] text-white font-[Rubik]">
    <main>
      <slot />
    </main>
  </body>
</html>
